  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start --reset-cache",
    "android:staging": "ENVFILE=.env.staging react-native run-android",
    "android:prod": "ENVFILE=.env.production react-native run-android",
    "ios:staging": "ENVFILE=.env.staging react-native run-ios",
    "ios:prod": "ENVFILE=.env.production react-native run-ios",
    "start:staging": "ENVFILE=.env.staging react-native start --reset-cache",
    "start:prod": "ENVFILE=.env.production react-native start --reset-cache",
    "build:android:staging": "ENVFILE=.env.staging cd android && ./gradlew assembleRelease",
    "build:android:prod": "ENVFILE=.env.production cd android && ./gradlew assembleRelease",
    "build:aab:staging": "ENVFILE=.env.staging cd android && ./gradlew bundleRelease",
    "build:aab:prod": "ENVFILE=.env.production cd android && ./gradlew bundleRelease",
    "web": "webpack serve --mode development",
    "build:web": "webpack --mode production",
    "lint": "eslint .",
    "test": "jest"
  },
